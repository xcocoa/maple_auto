<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Core -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Storage -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Device info -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Process management -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />

    <!-- Install -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name="com.maple.auto.app.MapleAutoApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MapleAuto"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Main UI Activity -->
        <activity
            android:name="com.maple.auto.app.ui.main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MapleAuto">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Keep Alive Service (main process) -->
        <service
            android:name="com.maple.auto.app.service.KeepAliveService"
            android:foregroundServiceType="dataSync" />

        <!-- Engine Service (:enginfloat process) -->
        <service
            android:name="com.maple.auto.engine.EngineService"
            android:process=":enginfloat"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <!-- Float Window Service (:enginfloat process) -->
        <service
            android:name="com.maple.auto.engine.floatwindow.FloatWindowService"
            android:process=":enginfloat"
            android:exported="false" />

        <!-- Accessibility Service (:enginfloat process) -->
        <service
            android:name="com.maple.auto.accessibility.AutoAccessibilityService"
            android:process=":enginfloat"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- Custom Input Method (:enginfloat process) -->
        <service
            android:name="com.maple.auto.engine.input.AutoInputMethod"
            android:process=":enginfloat"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Plugin Service (:daemon process) -->
        <service
            android:name="com.maple.auto.plugin.PluginService"
            android:process=":daemon"
            android:exported="false" />

        <!-- Shared Preference Provider (:remote process) -->
        <provider
            android:name="com.maple.auto.persistence.SharedPreferenceProvider"
            android:process=":remote"
            android:authorities="${applicationId}.preference"
            android:exported="false" />

        <!-- Boot Receiver -->
        <receiver
            android:name="com.maple.auto.app.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
