<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Mini mode indicator (small circle, hidden by default) -->
    <View
        android:id="@+id/float_mini_indicator"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/float_window_bg"
        android:visibility="gone" />

    <!-- Full toolbar container -->
    <LinearLayout
        android:id="@+id/float_toolbar_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/float_window_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <!-- State indicator dot -->
        <View
            android:id="@+id/float_state_indicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@android:color/darker_gray" />

        <!-- Play/Pause button -->
        <ImageButton
            android:id="@+id/float_btn_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_play_arrow_24"
            android:contentDescription="@string/float_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- Stop button -->
        <ImageButton
            android:id="@+id/float_btn_stop"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_stop_24"
            android:contentDescription="@string/float_stop"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/float_btn_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_settings_24"
            android:contentDescription="@string/float_settings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- Close button -->
        <ImageButton
            android:id="@+id/float_btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_close_24"
            android:contentDescription="@string/float_close"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Script name label (optional, shown below toolbar) -->
    <TextView
        android:id="@+id/float_tv_script_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CCFFFFFF"
        android:textSize="10sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone"
        android:background="@drawable/float_window_bg" />

</LinearLayout>
